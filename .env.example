# Copy to .env for local development.

DB_HOST=postgres
DB_PORT=5432
DB_NAME=chat
DB_USER=chat_app_user
DB_PASSWORD=chat_app_password
POSTGRES_PASSWORD=chat_app_password

CORS_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

AUTH_SERVICE_PORT=3001
CHAT_SERVICE_PORT=3002
AUTH_API_URL=http://auth-service:3001
CHAT_API_URL=http://chat-service:3002

JWT_PRIVATE_KEY=/app/jwt/private.key
JWT_PUBLIC_KEY=/app/jwt/public.key
JWT_EXPIRES_IN=7d

WEAVIATE_URL=http://weaviate:8080
LOCAL_LLM_URL=http://host.docker.internal:8082/v1/chat/completions

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENROUTER_API_KEY=
OPENROUTER_REFERER=http://localhost:3000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro-exp-03-25

# Local path to the Cloudflare named-tunnel credentials JSON.
# Keep this file out of git.
CLOUDFLARED_CREDENTIALS_FILE=/absolute/path/to/cloudflared-credentials.json

# Optional profiles:
#   public = nginx/cloudflared public tunnel
#   rag    = Weaviate + local transformer embeddings
# COMPOSE_PROFILES=public,rag
